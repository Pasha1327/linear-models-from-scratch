                            accuracy_score, confusion_matrix, classification_report,
                            roc_auc_score, roc_curve)
from sklearn.preprocessing import StandardScaler
from abc import ABC, abstractmethod
from sklearn.linear_model import LinearRegression as SklearnLinearRegression
from sklearn.linear_model import LogisticRegression as SklearnLogisticRegression




def test_linear_regression():
    """Тестирование линейной регрессии"""
    print("Тест линейной регрессии")
    
    # Загрузка данных
    diabetes = load_diabetes()
    X, y = diabetes.data, diabetes.target
    X_scaled = StandardScaler().fit_transform(X)
    
    # Разделение данных
    X_train, X_test, y_train, y_test = train_test_split(
        X_scaled, y, test_size=0.2, random_state=42
    )
    
    # Обучение моей модели
    print("Обучение моей модели LinearRegression")
    custom_model = LinearRegression(learning_rate=0.01, n_iterations=2000)
    custom_model.fit(X_train, y_train)
    
    # Обучение sklearn модели
    print("Обучение sklearn LinearRegression")
    sklearn_model = SklearnLinearRegression()
    sklearn_model.fit(X_train, y_train)
    
    # Предсказания
    y_pred_custom = custom_model.predict(X_test)
    y_pred_sklearn = sklearn_model.predict(X_test)
    
    # Метрики для моей модели
    mse_custom = mean_squared_error(y_test, y_pred_custom)
    mae_custom = mean_absolute_error(y_test, y_pred_custom)
    r2_custom = r2_score(y_test, y_pred_custom)
    
    # Метрики для sklearn модели
    mse_sklearn = mean_squared_error(y_test, y_pred_sklearn)
    mae_sklearn = mean_absolute_error(y_test, y_pred_sklearn)
    r2_sklearn = r2_score(y_test, y_pred_sklearn)
    
    # Вывод результатов
    print("\nМетрики качества:")
    print(f"{'Метрика':<20} {'Моя модель':<15} {'Sklearn':<15} {'Разница':<15}")
    print(f"{'-' * 65}")
    print(f"{'MSE':<20} {mse_custom:<15.4f} {mse_sklearn:<15.4f} {abs(mse_custom - mse_sklearn):<15.4f}")
    print(f"{'MAE':<20} {mae_custom:<15.4f} {mae_sklearn:<15.4f} {abs(mae_custom - mae_sklearn):<15.4f}")
    print(f"{'R²':<20} {r2_custom:<15.4f} {r2_sklearn:<15.4f} {abs(r2_custom - r2_sklearn):<15.4f}")
    
    # Визуализация
    plt.figure(figsize=(15, 5))
    
    # График 1: Сравнение предсказаний
    plt.subplot(1, 3, 1)
    plt.scatter(y_test, y_pred_custom, alpha=0.7, label='Моя модель', color='blue')
    plt.scatter(y_test, y_pred_sklearn, alpha=0.7, label='Sklearn', color='red', marker='x')
    plt.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], 'k--', lw=2)
    plt.xlabel('Истинные значения')
    plt.ylabel('Предсказанные значения')
    plt.title('Сравнение предсказаний')
    plt.legend()
    
    # График 2: История потерь
    plt.subplot(1, 3, 2)
    plt.plot(custom_model.loss_history)
    plt.xlabel('Итерация')
    plt.ylabel('MSE Loss')
    plt.title('История потерь при обучении')
    plt.grid(True, alpha=0.3)
    
    # График 3: Ошибки предсказаний
    plt.subplot(1, 3, 3)
    errors_custom = y_test - y_pred_custom
    errors_sklearn = y_test - y_pred_sklearn
    plt.hist(errors_custom, alpha=0.7, label='Моя модель', bins=30, color='blue')
    plt.hist(errors_sklearn, alpha=0.7, label='Sklearn', bins=30, color='red')
    plt.xlabel('Ошибка предсказания')
    plt.ylabel('Частота')
    plt.title('Распределение ошибок')
    plt.legend()
    
    plt.tight_layout()
    plt.show()
    
    return custom_model, sklearn_model

def test_logistic_regression():
    """Тестирование логистической регрессии"""
    print("Тест логистической регрессии")
    
    # Загрузка данных
    cancer = load_breast_cancer()
    X, y = cancer.data, cancer.target
    X_scaled = StandardScaler().fit_transform(X)
    
    # Разделение данных
    X_train, X_test, y_train, y_test = train_test_split(
        X_scaled, y, test_size=0.2, random_state=42, stratify=y
    )
    
    # Обучение моей модели
    print("Обучение моей модели LogisticRegression")
    custom_model = LogisticRegression(learning_rate=0.1, n_iterations=2000)
    custom_model.fit(X_train, y_train)
    
    # Обучение sklearn модели
    print("Обучение sklearn LogisticRegression")
    sklearn_model = SklearnLogisticRegression(max_iter=2000, random_state=42)
    sklearn_model.fit(X_train, y_train)
    
    # Предсказания
    y_pred_custom = custom_model.predict(X_test)
    y_pred_sklearn = sklearn_model.predict(X_test)
    y_proba_custom = custom_model.predict_proba(X_test)
    y_proba_sklearn = sklearn_model.predict_proba(X_test)[:, 1]
    
    # Метрики для моей модели
    accuracy_custom = accuracy_score(y_test, y_pred_custom)
    cm_custom = confusion_matrix(y_test, y_pred_custom)
    roc_auc_custom = roc_auc_score(y_test, y_proba_custom)
    
    # Метрики для sklearn модели
    accuracy_sklearn = accuracy_score(y_test, y_pred_sklearn)
    cm_sklearn = confusion_matrix(y_test, y_pred_sklearn)
    roc_auc_sklearn = roc_auc_score(y_test, y_proba_sklearn)
    
    # Вывод результатов
    print("\nМетрики качества:")
    print(f"{'Метрика':<20} {'Моя модель':<15} {'Sklearn':<15} {'Разница':<15}")
    print(f"{'-' * 65}")
    print(f"{'Accuracy':<20} {accuracy_custom:<15.4f} {accuracy_sklearn:<15.4f} {abs(accuracy_custom - accuracy_sklearn):<15.4f}")
    print(f"{'ROC AUC':<20} {roc_auc_custom:<15.4f} {roc_auc_sklearn:<15.4f} {abs(roc_auc_custom - roc_auc_sklearn):<15.4f}")
    
    print("\nMатрица ошибок (Моя модель):")
    print(cm_custom)
    print("\nMатрица ошибок (Sklearn):")
    print(cm_sklearn)
    
    print("\nОтчет классификации (Моя модель):")
    print(classification_report(y_test, y_pred_custom, target_names=cancer.target_names))
    
    # Визуализация
    plt.figure(figsize=(15, 5))
    
    # График 1: Матрицы ошибок
    plt.subplot(1, 3, 1)
    plt.imshow(cm_custom, interpolation='nearest', cmap='Blues')
    plt.title('Матрица ошибок (Моя модель)')
    plt.colorbar()
    tick_marks = np.arange(len(cancer.target_names))
    plt.xticks(tick_marks, cancer.target_names, rotation=45)
    plt.yticks(tick_marks, cancer.target_names)
    plt.ylabel('Истинный класс')
    plt.xlabel('Предсказанный класс')
    
    # Добавление текста в ячейки
    thresh = cm_custom.max() / 2.
    for i in range(cm_custom.shape[0]):
        for j in range(cm_custom.shape[1]):
            plt.text(j, i, format(cm_custom[i, j], 'd'),
                    ha="center", va="center",
                    color="white" if cm_custom[i, j] > thresh else "black")
    
    # График 2: История потерь
    plt.subplot(1, 3, 2)
    plt.plot(custom_model.loss_history)
    plt.xlabel('Итерация')
    plt.ylabel('Log Loss')
    plt.title('История потерь при обучении')
    plt.grid(True, alpha=0.3)
    
    # График 3: ROC кривые
    plt.subplot(1, 3, 3)
    fpr_custom, tpr_custom, _ = roc_curve(y_test, y_proba_custom)
    fpr_sklearn, tpr_sklearn, _ = roc_curve(y_test, y_proba_sklearn)
    
    plt.plot(fpr_custom, tpr_custom, label=f'Ваша модель (AUC = {roc_auc_custom:.3f})', color='blue')
    plt.plot(fpr_sklearn, tpr_sklearn, label=f'Sklearn (AUC = {roc_auc_sklearn:.3f})', color='red', linestyle='--')
    plt.plot([0, 1], [0, 1], 'k--', label='Случайный классификатор')
    plt.xlabel('False Positive Rate')
    plt.ylabel('True Positive Rate')
    plt.title('ROC кривые')
    plt.legend()
    plt.grid(True, alpha=0.3)
    
    plt.tight_layout()
    plt.show()
    
    return custom_model, sklearn_model

def test_auto_tune():
    """Тестирование автоматической настройки гиперпараметров"""
    print("Тест автоматической настройки параметров")
    
    # Тестирование для линейной регрессии
    diabetes = load_diabetes()
    X_diabetes, y_diabetes = diabetes.data, diabetes.target
    X_diabetes_scaled = StandardScaler().fit_transform(X_diabetes)
    
    print("Автонастройка LinearRegression...")
    lr_model = LinearRegression()
    best_params_lr, best_score_lr = lr_model.auto_tune(X_diabetes_scaled, y_diabetes)
    print(f"Лучшие параметры: {best_params_lr}")
    print(f"Лучший R²: {best_score_lr:.4f}")
    
    # Тестирование для логистической регрессии
    cancer = load_breast_cancer()
    X_cancer, y_cancer = cancer.data, cancer.target
    X_cancer_scaled = StandardScaler().fit_transform(X_cancer)
    
    print("\nАвтонастройка LogisticRegression...")
    log_model = LogisticRegression()
    best_params_log, best_score_log = log_model.auto_tune(X_cancer_scaled, y_cancer)
    print(f"Лучшие параметры: {best_params_log}")
    print(f"Лучшая Accuracy: {best_score_log:.4f}")

if __name__ == "__main__":
    # Запуск всех тестов
    print("Тесты для линейных моделей")
    
    # Тестирование линейной регрессии
    lr_custom, lr_sklearn = test_linear_regression()
    
    # Тестирование логистической регрессии
    log_custom, log_sklearn = test_logistic_regression()
    
    # Тестирование автонастройки
    test_auto_tune()
